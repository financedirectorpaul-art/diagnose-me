<!DOCTYPE html>
<html>
<head>
  <title>Diagnose Me — AI Health Platform</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root{--p700:#6d28d9;--p600:#7c3aed;--line:#e9d5ff}
    body{font-family:Arial;background:radial-gradient(circle,#7c3aed,#1e123d);color:#fff;text-align:center;padding:20px;margin:0}
    .wrap{max-width:900px;margin:auto}.card{background:#fff;color:#1e123d;padding:24px;border-radius:20px;margin-top:20px}
    button{padding:14px;border-radius:12px;border:none;margin:8px;font-weight:bold;cursor:pointer}
    .primary{background:linear-gradient(135deg,#6d28d9,#7c3aed);color:#fff}.ghost{background:#f5f3ff;color:#1e123d}.danger{background:#dc2626;color:#fff}
    input,textarea{width:90%;padding:12px;border-radius:12px;margin-top:10px}.tabs{display:flex;justify-content:center;gap:10px;margin-bottom:10px;flex-wrap:wrap}
    .tab{background:#eee;color:#1e123d;padding:10px 14px;border-radius:10px;font-weight:bold;cursor:pointer}.active{background:#6d28d9;color:#fff}
    .history,.plan,.box{background:#f5f3ff;border-radius:12px;padding:12px;margin-top:10px;text-align:left}.cta{background:linear-gradient(135deg,#6d28d9,#7c3aed);color:#fff;padding:16px;border-radius:16px;margin-top:20px}
    .meter{height:10px;background:#eee;border-radius:8px;overflow:hidden;margin:8px 0}.meter>div{height:100%;background:#6d28d9}
    #preview{max-width:100%;border-radius:12px;margin-top:10px;display:none}
  </style>
</head>
<body>
<div class="wrap">
  <h1>Diagnose Me</h1>
  <p><b>AI Triage Platform</b></p>
  <div class="tabs">
    <div class="tab" id="tab-consumer" onclick="setMode('consumer')">Consumer</div>
    <div class="tab" id="tab-health" onclick="setMode('health')">Health System</div>
    <div class="tab" id="tab-impact" onclick="setMode('impact')">Social Impact</div>
  </div>
  <div class="card" id="app"></div>
</div>

<script>
const AI_ENDPOINT = "/analyze";
let mode = "consumer";
let step = 0;
let answers = { text:"", imageBase64:"", imageMimeType:"", imageHint:"", mode:"consumer" };
let usageCount = parseInt(localStorage.getItem('usage')||'0');
const FREE_LIMIT = 5;

function setMode(m){
  mode = m; answers.mode = m; step = 0;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+m).classList.add('active');
  render();
}

function usageMeter(){
  const pct = Math.min(100, Math.round((usageCount/FREE_LIMIT)*100));
  return `<div class='meter'><div style='width:${pct}%'></div></div><div>${usageCount}/${FREE_LIMIT} free checks used</div>`;
}

function pricingConsumer(){
  return `<h2>Upgrade</h2>
  <div class='plan'><b>Free</b><br>${FREE_LIMIT} checks/month</div>
  <div class='plan'><b>Pro — $9.99/month</b><br>Unlimited checks, history and tracking<br><button class='primary' onclick='checkout("pro")'>Choose Pro</button></div>
  <div class='plan'><b>Family — $19.99/month</b><br>5 users<br><button class='primary' onclick='checkout("family")'>Choose Family</button></div>
  <button onclick='render()'>Back</button>`;
}

function pricingHealth(){
  return `<h2>Enterprise Pricing</h2>
  <div class='plan'><b>Starter — $1k/month</b><br>5 seats + basic reports</div>
  <div class='plan'><b>Clinic — $5k/month</b><br>25 seats + analytics</div>
  <div class='plan'><b>Hospital — Custom</b><br>API + integrations<br><button class='primary' onclick='contactSales()'>Contact Sales</button></div>
  <button onclick='render()'>Back</button>`;
}

function pricingImpact(){
  return `<h2>Support This Service</h2>
  <div class='plan'><b>$5/month</b><br>Helps keep access free</div>
  <div class='plan'><b>$20/month</b><br>Supports vulnerable users</div>
  <button class='primary' onclick='donate()'>Donate</button>
  <button onclick='render()'>Back</button>`;
}

function showProjections(){
  document.getElementById('app').innerHTML=`
    <h2>Revenue Projections</h2>
    <h3>Consumer</h3><p>10,000 users × 5% conversion × $9.99 = <b>~$5,000/month</b></p>
    <h3>Health System</h3><p>10 clients × $5,000/month = <b>$50,000/month</b></p>
    <h3>Social Impact</h3><p>Grants, sponsorships and donors = <b>$50k–$200k/year</b></p>
    <button onclick='render()'>Back</button>`;
}

function render(){
  const app = document.getElementById('app');

  if(mode === "consumer"){
    if(step===0){
      app.innerHTML=`<h2>Personal Health Check</h2><p>Know what to do next in seconds</p>${usageMeter()}
      <button class="primary" onclick="step=1;render()">Start</button>
      <button class="ghost" onclick="showHistory()">History</button>
      <button class="ghost" onclick="app.innerHTML=pricingConsumer()">Pricing</button>
      <button class="ghost" onclick="showProjections()">Revenue Projections</button>`;
    }
    if(step===1) inputScreen("Describe Symptoms", "e.g. sore wrist after fall, rash, bite, headache");
  }

  if(mode === "health"){
    if(step===0){
      app.innerHTML=`<h2>Clinical Triage Tool</h2><p>AI-assisted triage for faster decisions</p>
      <button class="primary" onclick="step=1;render()">Start Triage</button>
      <button class="ghost" onclick="app.innerHTML=pricingHealth()">Pricing</button>`;
    }
    if(step===1) inputScreen("Patient Summary", "Enter patient symptoms / notes");
  }

  if(mode === "impact"){
    if(step===0){
      app.innerHTML=`<h2>Support & Safety Check</h2><p>Confidential guidance when it matters most</p>
      <button class="primary" onclick="step=1;render()">Start</button>
      <button class="danger" onclick="quickExit()">Quick Exit</button>
      <button class="ghost" onclick="app.innerHTML=pricingImpact()">Support</button>`;
    }
    if(step===1) inputScreen("What's happening?", "Describe situation or health/safety concern");
  }
}

function inputScreen(title, placeholder){
  document.getElementById('app').innerHTML=`
    <h3>${title}</h3>
    <textarea rows="5" placeholder="${placeholder}" oninput="answers.text=this.value"></textarea>
    <div class="box"><b>Optional photo</b><br><input type="file" accept="image/*" onchange="upload(this)"><img id="preview"></div>
    <button class="primary" onclick="analyze()">Analyse</button>`;
}

function upload(inp){
  const f = inp.files[0];
  if(!f) return;
  answers.imageMimeType = f.type || "image/jpeg";
  const r = new FileReader();
  r.onload = () => { answers.imageBase64 = r.result; const p=document.getElementById("preview"); p.src=r.result; p.style.display="block"; };
  r.readAsDataURL(f);
}

function quickExit(){ window.location.href = "https://www.google.com"; }
function donate(){ alert("Donation link goes here"); }
function contactSales(){ alert("Contact: sales@diagnoseme.com"); }
function checkout(plan){ alert("Stripe checkout goes here: "+plan); }

function saveHistory(out){
  let h = JSON.parse(localStorage.getItem('history')||'[]');
  h.push({time:new Date().toLocaleString(),result:out.nextStep});
  localStorage.setItem('history',JSON.stringify(h));
}

function showHistory(){
  let h = JSON.parse(localStorage.getItem('history')||'[]');
  let html = '<h2>History</h2>';
  h.reverse().forEach(x=> html += `<div class='history'><b>${x.time}</b><br>${x.result}</div>`);
  html += `<button onclick='render()'>Back</button>`;
  document.getElementById('app').innerHTML = html;
}

async function analyze(){
  usageCount++;
  localStorage.setItem('usage', usageCount);

  if(mode==='consumer' && usageCount > FREE_LIMIT){
    document.getElementById('app').innerHTML = pricingConsumer();
    return;
  }

  document.getElementById('app').innerHTML="<h2>Analysing with Clinical AI...</h2>";

  try {
    const res = await fetch(AI_ENDPOINT,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(answers)
    });
    const out = await res.json();
    saveHistory(out);

    const causes = (out.causes || []).map(c => `<li><b>${c.name}</b> (${c.confidence}%): ${c.reason}</li>`).join("");
    const treatment = (out.treatment || []).map(t => `<li>${t}</li>`).join("");
    const redFlags = (out.redFlags || []).map(r => `<li>${r}</li>`).join("");

    let extra = "";
    if(mode === "consumer"){
      extra = `<button class='primary' onclick='window.open("https://healthdirect.gov.au")'>Talk to GP</button><button class='ghost' onclick='analyze()'>Check Again Later</button>`;
    }
    if(mode === "health"){
      extra = `<div class='cta'>Risk Level: ${out.urgency || (out.confidence > 80 ? 'High' : 'Moderate')}</div><button class='ghost' onclick='window.print()'>Export Report</button>`;
    }
    if(mode === "impact"){
      extra = `<div class='cta'>If unsafe, contact emergency services or a support hotline immediately</div>`;
    }

    document.getElementById('app').innerHTML=`
      <h2>Result</h2>
      <p><b>${out.nextStep}</b></p>
      <p><b>Urgency:</b> ${out.urgency} | <b>Confidence:</b> ${out.confidence}%</p>
      <div class="box"><h3>Possible causes</h3><ul>${causes}</ul></div>
      <div class="box"><h3>Basic care</h3><ul>${treatment}</ul></div>
      <div class="box"><h3>Red flags</h3><ul>${redFlags}</ul></div>
      ${extra}
      <button onclick="step=0;render()">Restart</button>`;
  } catch(e) {
    document.getElementById('app').innerHTML=`<h2>Error</h2><p>Clinical AI connection failed.</p><p>${e.message}</p><button onclick="step=0;render()">Back</button>`;
  }
}

setMode('consumer');
</script>
</body>
</html>